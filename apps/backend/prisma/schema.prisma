// ============================================================
// FixHub — Production Database Schema
// PostgreSQL 16 via Prisma ORM
//
// Design: Principal Solution Architect
// Version: 2.0.0
// Last Updated: 2025-07-13
//
// Conventions:
//   • UUID v4 for all primary keys
//   • snake_case table/column names via @map / @@map
//   • Decimal(10,2) for all monetary values
//   • Soft delete via deletedAt on critical entities
//   • Audit fields: createdAt, updatedAt, createdBy, updatedBy
//   • Immutable entities: no updatedAt / updatedBy
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  ASSIGNED
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  PRICE_REVISION_PENDING // Technician proposed a revised price; awaiting customer consent
  COMPLETED
  CANCELLED
  FAILED
}

enum JobOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentTransactionType {
  AUTHORIZE
  CAPTURE
  REFUND
  FAILURE
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  COD
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaUploadPhase {
  BEFORE_SERVICE
  DURING_SERVICE
  AFTER_SERVICE
}

enum DocumentType {
  AADHAAR
  PAN
  DRIVING_LICENSE
  CERTIFICATE
  OTHER
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum NotificationType {
  BOOKING_UPDATE
  PAYMENT_UPDATE
  ASSIGNMENT
  REVIEW
  SYSTEM
  PROMOTIONAL
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum CancellationActor {
  CUSTOMER
  TECHNICIAN
  ADMIN
  SYSTEM
}

// ============================================================
// IDENTITY & ACCESS
// ============================================================

/// Central identity table. Every person is a User first,
/// with role-specific profiles via 1:1 Customer/Technician.
model User {
  id        String    @id @default(uuid()) @db.Uuid
  phone     String    @unique
  email     String?   @unique
  password  String?
  name      String?
  role      Role
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // 1:1 role profiles
  customer   Customer?
  technician Technician?

  // Auth
  refreshTokens RefreshToken[]
  deviceTokens  DeviceToken[]

  // Communication
  notifications Notification[]

  // Audit
  auditLogs AuditLog[] @relation("AuditActor")

  @@index([phone])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

/// Opaque refresh tokens for JWT rotation.
/// Stored in DB (not Redis) for revocation audit trail.
/// Hard-deleted via scheduled cleanup after expiry.
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// FCM/APNS registration token per device.
/// One user can have multiple devices.
model DeviceToken {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  token     String         @unique
  platform  DevicePlatform
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

/// Granular permission for RBAC.
/// Allows admin panel to manage fine-grained access.
model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  action      String  @unique // e.g., "booking:create", "technician:verify"
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

/// Junction: Role ↔ Permission mapping.
/// Composite unique on (role, permissionId).
model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  role         Role
  permissionId String @map("permission_id") @db.Uuid

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

// ============================================================
// CUSTOMER DOMAIN
// ============================================================

/// Extended profile for users with role=CUSTOMER.
/// Separated from User because not all users are customers.
model Customer {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  profilePictureUrl String?   @map("profile_picture_url")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses Address[]
  bookings  Booking[]
  reviews   Review[]

  @@index([deletedAt])
  @@map("customers")
}

/// Customer's saved addresses for service delivery.
/// Soft-deletable because bookings reference historical addresses.
model Address {
  id         String    @id @default(uuid()) @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  label      String    @default("Home") // Home, Work, Other
  line1      String    @map("line_1")
  line2      String?   @map("line_2")
  landmark   String?
  city       String
  state      String
  pincode    String
  latitude   Decimal   @db.Decimal(10, 7)
  longitude  Decimal   @db.Decimal(10, 7)
  isDefault  Boolean   @default(false) @map("is_default")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([customerId])
  @@index([pincode])
  @@index([deletedAt])
  @@map("addresses")
}

// ============================================================
// TECHNICIAN DOMAIN
// ============================================================

/// Extended profile for service workers.
/// verificationStatus tracks PENDING → UNDER_REVIEW → VERIFIED / REJECTED.
model Technician {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  profilePictureUrl  String?            @map("profile_picture_url")
  isAvailable        Boolean            @default(false) @map("is_available")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  rating             Decimal            @default(0) @db.Decimal(3, 2) // 0.00 – 5.00
  totalJobs          Int                @default(0) @map("total_jobs")
  // Live location — updated by mobile GPS
  latitude           Decimal?           @db.Decimal(10, 7)
  longitude          Decimal?           @db.Decimal(10, 7)
  lastLocationAt     DateTime?          @map("last_location_at")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAreas    TechnicianServiceArea[]
  specializations TechnicianSpecialization[]
  documents       TechnicianDocument[]
  bookings        Booking[]
  reviews         Review[]
  jobOffers       JobOffer[]

  @@index([isAvailable, verificationStatus])
  @@index([deletedAt])
  @@map("technicians")
}

/// Junction: Technician ↔ ServiceArea.
/// "Which geographic areas does this technician serve?"
model TechnicianServiceArea {
  id            String @id @default(uuid()) @db.Uuid
  technicianId  String @map("technician_id") @db.Uuid
  serviceAreaId String @map("service_area_id") @db.Uuid

  technician  Technician  @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([technicianId, serviceAreaId])
  @@index([serviceAreaId])
  @@map("technician_service_areas")
}

/// Junction: Technician ↔ SubService.
/// "Which specific services can this technician perform?"
/// Critical for matching: "Find electricians who do fan repair in Kolathur."
model TechnicianSpecialization {
  id           String @id @default(uuid()) @db.Uuid
  technicianId String @map("technician_id") @db.Uuid
  subServiceId String @map("sub_service_id") @db.Uuid

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  subService SubService @relation(fields: [subServiceId], references: [id], onDelete: Cascade)

  @@unique([technicianId, subServiceId])
  @@index([subServiceId])
  @@map("technician_specializations")
}

/// Identity proofs, certificates uploaded by technician.
/// documentType enum for strong typing.
/// verifiedAt + verifiedBy for audit trail.
model TechnicianDocument {
  id            String       @id @default(uuid()) @db.Uuid
  technicianId  String       @map("technician_id") @db.Uuid
  documentType  DocumentType @map("document_type")
  url           String
  s3Key         String       @map("s3_key")
  isVerified    Boolean      @default(false) @map("is_verified")
  verifiedAt    DateTime?    @map("verified_at")
  verifiedBy    String?      @map("verified_by") @db.Uuid // admin userId
  rejectionNote String?      @map("rejection_note")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@index([documentType])
  @@map("technician_documents")
}

// ============================================================
// SERVICE CATALOG
// ============================================================

/// Geographic zones where FixHub operates.
/// Pincode-based. One pincode = one service area.
/// Expandable to GeoJSON polygons in the future.
model ServiceArea {
  id        String    @id @default(uuid()) @db.Uuid
  name      String // e.g., "Kolathur"
  pincode   String    @unique
  city      String
  state     String
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  technicians     TechnicianServiceArea[]
  subServiceAreas SubServiceArea[]

  @@index([city])
  @@index([isActive])
  @@index([deletedAt])
  @@map("service_areas")
}

/// Top-level service group.
/// e.g., Electrical, AC Service, Plumbing
model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  slug      String    @unique
  iconUrl   String?   @map("icon_url")
  isActive  Boolean   @default(true) @map("is_active")
  sortOrder Int       @default(0) @map("sort_order")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  subServices SubService[]

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("categories")
}

/// Specific service within a category.
/// e.g., Fan Repair (under Electrical)
/// Decimal for basePrice — never Float for money.
model SubService {
  id                    String    @id @default(uuid()) @db.Uuid
  categoryId            String    @map("category_id") @db.Uuid
  name                  String
  slug                  String    @unique
  description           String?
  basePrice             Decimal   @map("base_price") @db.Decimal(10, 2)
  estimatedDurationMins Int       @map("estimated_duration_mins") // in minutes
  iconUrl               String?   @map("icon_url")
  isActive              Boolean   @default(true) @map("is_active")
  sortOrder             Int       @default(0) @map("sort_order")
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdBy             String?   @map("created_by") @db.Uuid
  updatedBy             String?   @map("updated_by") @db.Uuid

  category        Category                   @relation(fields: [categoryId], references: [id])
  bookings        Booking[]
  specializations TechnicianSpecialization[]
  activeAreas     SubServiceArea[]

  @@index([categoryId, isActive, sortOrder])
  @@index([deletedAt])
  @@map("sub_services")
}

// ============================================================
// BOOKING DOMAIN
// ============================================================

/// Core transaction entity. Status-driven lifecycle with 11 states.
/// bookingNumber is human-readable: FH-YYYYMMDD-NNNN
/// Most indexed table — optimized for read-heavy customer/technician queries.
model Booking {
  id                String             @id @default(uuid()) @db.Uuid
  bookingNumber     String             @unique @map("booking_number") // FH-20250713-0001
  customerId        String             @map("customer_id") @db.Uuid
  technicianId      String?            @map("technician_id") @db.Uuid
  subServiceId      String             @map("sub_service_id") @db.Uuid
  addressId         String             @map("address_id") @db.Uuid
  status            BookingStatus      @default(DRAFT)
  scheduledDate     DateTime           @map("scheduled_date") @db.Date
  scheduledSlot     String             @map("scheduled_slot") // e.g., "10:00-12:00"
  description       String?
  totalAmount       Decimal            @map("total_amount") @db.Decimal(10, 2)
  notes             String? // Internal notes (admin/technician)
  // Price revision — technician can propose a revised price after inspection
  revisedAmount     Decimal?           @map("revised_amount") @db.Decimal(10, 2)
  priceRevisionNote String?            @map("price_revision_note")
  customerConsentAt DateTime?          @map("customer_consent_at")
  // Completion
  completedAt       DateTime?          @map("completed_at")
  // Cancellation
  cancelledAt       DateTime?          @map("cancelled_at")
  cancelledBy       CancellationActor? @map("cancelled_by")
  cancelReason      String?            @map("cancel_reason")
  // Failure
  failedAt          DateTime?          @map("failed_at")
  failureReason     String?            @map("failure_reason")
  // Audit
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  createdBy         String?            @map("created_by") @db.Uuid
  updatedBy         String?            @map("updated_by") @db.Uuid

  // Relations
  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])
  subService SubService  @relation(fields: [subServiceId], references: [id])
  address    Address     @relation(fields: [addressId], references: [id])

  timeline  BookingTimeline[]
  media     BookingMedia[]
  payment   Payment?
  review    Review?
  jobOffers JobOffer[]

  // Composite indexes optimized for read-heavy queries
  @@index([customerId, status]) // "List my bookings" — Customer app
  @@index([technicianId, status]) // "List my jobs" — Technician app
  @@index([scheduledDate, status]) // Schedule view, admin dashboard
  @@index([status, createdAt(sort: Desc)]) // Admin booking list
  @@map("bookings")
}

/// Immutable log of every booking status transition.
/// Captures who changed it, optional note, and location at transition time.
/// Never updated, never deleted.
model BookingTimeline {
  id              String        @id @default(uuid()) @db.Uuid
  bookingId       String        @map("booking_id") @db.Uuid
  status          BookingStatus
  changedByUserId String        @map("changed_by_user_id") @db.Uuid
  note            String?
  // Location at the time of status change (useful for EN_ROUTE, ARRIVED)
  latitude        Decimal?      @db.Decimal(10, 7)
  longitude       Decimal?      @db.Decimal(10, 7)
  createdAt       DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt(sort: Desc)])
  @@map("booking_timeline")
}

/// Photos/videos uploaded during service.
/// Tracks uploadPhase for proof-of-work documentation.
model BookingMedia {
  id              String           @id @default(uuid()) @db.Uuid
  bookingId       String           @map("booking_id") @db.Uuid
  url             String
  s3Key           String           @map("s3_key")
  type            MediaType
  uploadPhase     MediaUploadPhase @map("upload_phase")
  uploadedBy      String           @map("uploaded_by") @db.Uuid // userId
  durationSeconds Int?             @map("duration_seconds") // videos only; max 60 enforced in DTO
  createdAt       DateTime         @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_media")
}

// ============================================================
// PAYMENT DOMAIN
// ============================================================

/// One-to-one with a Booking via Razorpay order.
/// Tracks high-level payment status.
/// Unique on bookingId — one payment order per booking.
model Payment {
  id                String         @id @default(uuid()) @db.Uuid
  bookingId         String         @unique @map("booking_id") @db.Uuid
  razorpayOrderId   String?        @unique @map("razorpay_order_id")
  razorpayPaymentId String?        @unique @map("razorpay_payment_id")
  razorpaySignature String?        @map("razorpay_signature")
  amount            Decimal        @db.Decimal(10, 2)
  currency          String         @default("INR")
  status            PaymentStatus  @default(PENDING)
  method            PaymentMethod?
  failureReason     String?        @map("failure_reason")
  paidAt            DateTime?      @map("paid_at")
  refundedAt        DateTime?      @map("refunded_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  booking      Booking              @relation(fields: [bookingId], references: [id])
  transactions PaymentTransaction[]

  @@index([status])
  @@map("payments")
}

/// Individual events on a payment.
/// One Payment can have multiple events (authorize, capture, partial refunds).
/// Maps 1:1 with Razorpay webhook events. Append-only, never updated.
model PaymentTransaction {
  id              String                 @id @default(uuid()) @db.Uuid
  paymentId       String                 @map("payment_id") @db.Uuid
  type            PaymentTransactionType
  razorpayEventId String?                @unique @map("razorpay_event_id")
  amount          Decimal                @db.Decimal(10, 2)
  status          String // Raw status from gateway
  gatewayResponse Json?                  @map("gateway_response")
  createdAt       DateTime               @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_transactions")
}

// ============================================================
// COMMUNICATION
// ============================================================

/// In-app notification history.
/// type is an enum for reliable filtering.
/// data JSON only for deep-link payloads — not structural data.
model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String
  body      String
  type      NotificationType
  data      Json? // Deep-link payload: { bookingId, screen, etc. }
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================
// FEEDBACK
// ============================================================

/// Post-booking rating. 1:1 with Booking.
/// rating constrained 1–5.
/// Once submitted, never deleted (moderation via separate flag if needed).
model Review {
  id           String   @id @default(uuid()) @db.Uuid
  bookingId    String   @unique @map("booking_id") @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  technicianId String   @map("technician_id") @db.Uuid
  rating       Int // 1–5, enforced via application layer + CHECK constraint in migration
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  booking    Booking    @relation(fields: [bookingId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])
  technician Technician @relation(fields: [technicianId], references: [id])

  @@index([technicianId])
  @@index([customerId])
  @@map("reviews")
}

// ============================================================
// JOB OFFERS (broadcast/eligibility model)
// ============================================================

/// Represents an offer sent to a technician for a CONFIRMED booking.
/// Created when admin assigns or system broadcasts to eligible technicians.
/// Technician has 15 minutes (expiresAt) to accept or reject.
/// First ACCEPTED offer wins; others are EXPIRED.
model JobOffer {
  id           String         @id @default(uuid()) @db.Uuid
  bookingId    String         @map("booking_id") @db.Uuid
  technicianId String         @map("technician_id") @db.Uuid
  status       JobOfferStatus @default(PENDING)
  offeredAt    DateTime       @default(now()) @map("offered_at")
  expiresAt    DateTime       @map("expires_at") // offeredAt + 15 min
  respondedAt  DateTime?      @map("responded_at")

  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId, status])
  @@index([bookingId, status])
  @@index([expiresAt])
  @@map("job_offers")
}

// ============================================================
// CATALOG EXTENSIONS
// ============================================================

/// Junction: SubService ↔ ServiceArea.
/// Restricts a sub-service to specific geographic areas.
/// If no rows exist for a sub-service, it is available in all active areas (opt-in restriction).
model SubServiceArea {
  id            String @id @default(uuid()) @db.Uuid
  subServiceId  String @map("sub_service_id") @db.Uuid
  serviceAreaId String @map("service_area_id") @db.Uuid

  subService  SubService  @relation(fields: [subServiceId], references: [id], onDelete: Cascade)
  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([subServiceId, serviceAreaId])
  @@index([serviceAreaId])
  @@map("sub_service_areas")
}

// ============================================================
// OBSERVABILITY
// ============================================================

/// Immutable record of data mutations.
/// oldValue/newValue as JSON snapshots.
/// Never deleted, never updated.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String // CREATE, UPDATE, DELETE
  entity    String // Table/model name
  entityId  String   @map("entity_id") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation("AuditActor", fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ============================================================
// SYSTEM
// ============================================================

/// Dynamic configuration for the platform
/// e.g. business_hours, pricing_rules, cancellation_policy
model PlatformSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("platform_settings")
}
