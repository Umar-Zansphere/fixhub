# ===========================================
# FixHub Environment Configuration
# Copy this file to .env and fill in values
# ===========================================

# ----- Application -----
NODE_ENV=development
APP_PORT=3000
APP_NAME=FixHub
API_PREFIX=api
API_VERSION=v1

# ----- Database (PostgreSQL) -----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fixhub
DB_PASSWORD=fixhub_secret
DB_NAME=fixhub_dev
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- JWT -----
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ----- OTP -----
OTP_EXPIRATION_SECONDS=300
OTP_LENGTH=6

# ----- AWS S3 -----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=fixhub-uploads
AWS_S3_SIGNED_URL_EXPIRY=3600

# ----- Razorpay -----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----- Firebase -----
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ----- Rate Limiting -----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ----- CORS -----
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ----- Admin Panel (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=FixHub Admin
